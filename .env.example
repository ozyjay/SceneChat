SCENECHAT_MODE=live
SCENECHAT_HOST=127.0.0.1
SCENECHAT_PORT=3700

CAMERA_DEVICE=0
CAMERA_WIDTH=1280
CAMERA_HEIGHT=720
CAMERA_FPS=30

DETECTOR_BACKEND=auto
DETECTOR_MODEL=models/yolov8s-worldv2.pt
DETECTOR_MODEL_OPTIONS={"yoloe-26s":"models/yoloe-26s-seg.pt","yoloworld-s":"models/yolov8s-worldv2.pt"}
DETECTOR_CONFIDENCE=0.40
DETECTOR_MAX_FPS=5
DETECTOR_TEXT_ENCODER=models/mobileclip2_b.ts
DETECTOR_YOLOWORLD_CLIP=models/ViT-B-32.pt
DETECTOR_PROMPTS=["person","computer mouse","keyboard","laptop","monitor"]
DETECTOR_PROMPT_ALLOWLIST=["person","computer mouse","keyboard","laptop","monitor","mobile phone","camera","microphone","bottle","cup","chair","table","book","backpack","cabinet","headphones","pen","paper","glasses","potted plant"]
DETECTOR_PROMPT_AUTO_UPDATE=false
# Supported live detector backends are yoloe, yoloworld, or auto for an allowlist containing both.

MODEL_PROVIDER=modeldeck
# SceneChat uses only the stable gateway. Start the Worker separately in ModelDeck.
# Do not copy ModelDeck's private Worker credential into this file.
MODELDECK_URL=http://127.0.0.1:8600
MODELDECK_MODEL=scenechat-vision
VISION_REQUEST_TIMEOUT_SECONDS=20
VISION_ANALYSIS_MAX_EDGE=0
VISION_MAX_TOKENS=512
AUTO_ANALYSE=false
AUTO_ANALYSE_INTERVAL_SECONDS=20

STORE_FRAMES=false
STORE_VIDEO=false
REPLAY_SCENARIO=demo_booth
