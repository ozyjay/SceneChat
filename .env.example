SCENECHAT_MODE=live
SCENECHAT_HOST=127.0.0.1
SCENECHAT_PORT=3700

CAMERA_DEVICE=0
CAMERA_WIDTH=1280
CAMERA_HEIGHT=720
CAMERA_FPS=30

DETECTOR_BACKEND=auto
DETECTOR_MODEL=models/yoloe-26s-seg.pt
DETECTOR_MODEL_OPTIONS={"yoloe-26s":"models/yoloe-26s-seg.pt","yoloworld-s":"models/yolov8s-worldv2.pt"}
DETECTOR_CONFIDENCE=0.40
DETECTOR_MAX_FPS=5
DETECTOR_TEXT_ENCODER=models/mobileclip2_b.ts
DETECTOR_YOLOWORLD_CLIP=models/ViT-B-32.pt
DETECTOR_PROMPTS=["person","computer mouse","keyboard","laptop","monitor"]
DETECTOR_PROMPT_ALLOWLIST=["person","computer mouse","keyboard","laptop","monitor","mobile phone","camera","microphone","bottle","cup","chair","table","book","backpack","cabinet"]
DETECTOR_PROMPT_AUTO_UPDATE=false
# Supported live detector backends are yoloe, yoloworld, or auto for an allowlist containing both.

MODEL_PROVIDER=modeldeck
MODELDECK_URL=http://127.0.0.1:8600
MODELDECK_API_KEY=
MODELDECK_MODEL=scenechat-vision
MODEL_FALLBACK_MODE=replay
VISION_REQUEST_TIMEOUT_SECONDS=20
AUTO_ANALYSE=false
AUTO_ANALYSE_INTERVAL_SECONDS=5

STORE_FRAMES=false
STORE_VIDEO=false
REPLAY_SCENARIO=demo_booth
